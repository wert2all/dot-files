{
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    },
    "context7": {
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      }
    },
    "github": {
      "command": "npx",
      "auth": "bearer",
      "bearerTokenEnv": "GITHUB_TOKEN",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ]
    }
  }
}
